# ── Data paths ───────────────────────────────────────────────────────────
DATA_5G_PATH=../MoE/Global_CLEANED.csv
DATA_6G_PATH=../MoE/AIoT_6G_CLEANED.csv

# ── Artefact storage ─────────────────────────────────────────────────────
ARTEFACTS_DIR=artefacts
MODEL_VERSION=v1

# ── Training hyperparams ─────────────────────────────────────────────────
SEED=42
XGB_N_ESTIMATORS=200
XGB_MAX_DEPTH=5
XGB_LEARNING_RATE=0.1
AE_EPOCHS=80
AE_BATCH_SIZE=64
AE_BOTTLENECK=6
GATE_EPOCHS=80
GATE_BATCH_SIZE=128
TEST_SIZE=0.2
VAL_SIZE=0.15
ANOMALY_FRACTION=0.15

# ── Inference ─────────────────────────────────────────────────────────────
PREDICTION_THRESHOLD=0.5
MAX_BATCH_FILE_MB=100

# ── MLflow ────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=unified_moe

# ── Promotion thresholds ─────────────────────────────────────────────────
MIN_F1=0.90
MIN_RECALL=0.95
MIN_PR_AUC=0.92

# ── API ───────────────────────────────────────────────────────────────────
API_KEY=changeme
WEBAPP_ORIGIN=http://localhost:3000
LOG_DIR=logs/predictions