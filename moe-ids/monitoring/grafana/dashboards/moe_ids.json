{
  "title": "MoE IDS — Inference Monitoring",
  "uid": "moe-ids-v1",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(moe_ids_requests_total[1m]) * 60",
          "legendFormat": "{{schema}} / {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 Latency (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(moe_ids_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{schema}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Attack Rate — Last Batch",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.3}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "moe_ids_attack_rate_last_batch",
          "legendFormat": "{{schema}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Rows Processed (total)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "sum(moe_ids_rows_processed_total)",
          "legendFormat": "Total rows"
        }
      ]
    },
    {
      "id": 5,
      "title": "Attack vs Benign Predictions",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "rate(moe_ids_attack_predictions_total[5m])",
          "legendFormat": "attack {{schema}}"
        },
        {
          "expr": "rate(moe_ids_rows_processed_total[5m]) - rate(moe_ids_attack_predictions_total[5m])",
          "legendFormat": "benign {{schema}}"
        }
      ]
    },

    {
      "id": 100,
      "type": "row",
      "title": "Machine metrics (node-exporter)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "collapsed": false
    },
    {
      "id": 101,
      "title": "Host CPU Usage (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 17},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "targets": [
        {
          "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 102,
      "title": "Host Memory Free (%)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 17},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 15},
              {"color": "green", "value": 30}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100",
          "legendFormat": "free"
        }
      ]
    },
    {
      "id": 103,
      "title": "Host Disk Free",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 17},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {
          "expr": "min(node_filesystem_avail_bytes{mountpoint=\"/host\"})",
          "legendFormat": "free"
        }
      ]
    },

    {
      "id": 200,
      "type": "row",
      "title": "Container metrics (cadvisor)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "collapsed": false
    },
    {
      "id": 201,
      "title": "Container CPU (core-seconds/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"moe_.*|ids_.*\"}[1m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 202,
      "title": "Container Memory (RSS)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {
          "expr": "container_memory_rss{name=~\"moe_.*|ids_.*\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },

    {
      "id": 300,
      "type": "row",
      "title": "Model quality (from last training run)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34},
      "collapsed": false
    },
    {
      "id": 301,
      "title": "Accuracy",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 35},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.8},
              {"color": "green", "value": 0.9}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "moe_ids_model_accuracy",
          "legendFormat": "accuracy"
        }
      ]
    },
    {
      "id": 302,
      "title": "F1",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 35},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.8},
              {"color": "green", "value": 0.9}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "moe_ids_model_f1",
          "legendFormat": "f1"
        }
      ]
    },
    {
      "id": 303,
      "title": "ROC AUC",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 35},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.85},
              {"color": "green", "value": 0.95}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "moe_ids_model_auc",
          "legendFormat": "auc"
        }
      ]
    },
    {
      "id": 304,
      "title": "Model Age (s)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 35},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "time() - moe_ids_model_run_ts",
          "legendFormat": "age"
        }
      ]
    }
  ]
}
