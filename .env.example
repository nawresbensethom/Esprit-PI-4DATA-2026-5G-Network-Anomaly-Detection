# ─── Root .env for the unified IDS platform ──────────────────────────────
# Copy to .env and fill in any secrets before running `docker compose up -d`.
# Every variable has a sane default in docker-compose.yml; this file lists the
# knobs worth tweaking per environment.

# ── Dashboard Postgres (auth + users + prediction history) ───────────────
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard123
POSTGRES_DB=dashboard

# ── JWT signing key (gateway + auth-svc must share this) ─────────────────
JWT_SECRET=change-this-in-production-to-a-64-char-random-string

# ── MinIO (S3-compatible object store for uploads/exports) ───────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ── Internal service-to-service API key (gateway → ML microservices) ─────
# Any value other than "changeme" enables auth at the moe-* services.
INTERNAL_API_KEY=changeme

# ── Frontend (baked into the Next.js build) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8090
WEBAPP_ORIGIN=http://localhost:3000

# ── Grafana admin password ───────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Slack webhook (optional) — drift alerts + CI/CD notifications ────────
# Get one from: Slack app → Incoming Webhooks. Leave empty to disable.
SLACK_WEBHOOK_URL=
